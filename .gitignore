/.claude/skills

# Python environments and packaging artifacts
/.venv/
/venv/
/env/
/build/
/dist/
/*.egg-info/
/.pytest_cache/
/.ruff_cache/
/.mypy_cache/
/.coverage
/coverage.xml

# Python bytecode
__pycache__/
*.py[cod]

# macOS and editor noise
.DS_Store
.idea/
.vscode/

# Logs and local scratch files
*.log
*.tmp
*.swp
