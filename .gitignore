/planning/
/evals/*
/scripts/private/
/skills/private/
/IMPLEMENTATION_PLAN.md

# Generated agent adapters
/.agents/
/.github/skills/

# Repo-local generated skill shims
/.claude/skills

# Repo-local toolchain and bootstrap state
/.docmason/

# Python environments and packaging artifacts
/.venv/
/venv/
/env/
/build/
/dist/
/*.egg-info/
/.pytest_cache/
/.ruff_cache/
/.mypy_cache/
/.coverage
/.coverage.*
/coverage.xml
/htmlcov/
/.hypothesis/
/.tox/
/.nox/
/.cache/

# Python bytecode
__pycache__/
*.py[cod]

# Local environment and machine-specific config
.env
.env.*
.python-version
.direnv/
.envrc

# macOS and editor noise
.DS_Store
.idea/
.vscode/

