!/knowledge_base/.gitkeep
/runtime/*
!/runtime/.gitkeep
/adapters/*
!/adapters/.gitkeep
/planning/
/skills/private/
/IMPLEMENTATION_PLAN.md

# Generated agent adapters
/CLAUDE.md
/.github/copilot-instructions.md
/.github/skills/

